# ─── AI ─────────────────────────────────────────────────────────────────────
# Google AI Studio key — https://aistudio.google.com (free, no credit card)
GOOGLE_API_KEY=your_key_here

# Demo mode: real | simulated  (real uses Gemini for narration; simulated uses canned text)
AGENT_MODE=simulated

# ─── Bindings ───────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ─── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. NEVER use "*".
# Cloud Run example: set both ops + companion URLs here.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Ops Authentication ────────────────────────────────────────────────────
# Shared-secret bearer token for ops endpoints (Phase 0). Phase 1+: replace
# with Identity Platform / OIDC. Generate a fresh one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
OPS_TOKEN=

# Production: set to true. Refuses to start without OPS_TOKEN, blocks
# unauthenticated callers, and removes /docs + /openapi.json.
# Dev/demo: leave false — backend warns about missing auth but allows traffic.
OPS_AUTH_ENFORCE=false

# ─── Hardening flags ───────────────────────────────────────────────────────
# Enable HSTS — ONLY when terminating TLS at an upstream proxy.
ENABLE_HSTS=false

# Strip exception details from 5xx responses (recommended true in production)
REDACT_ERRORS=true

# Max WebSocket payload (server → client) in bytes. Oversized events
# are sent with a truncation marker instead.
WS_MAX_MESSAGE_BYTES=32768

# Max events retained in the bus history (memory cap)
BUS_HISTORY_MAX=5000
